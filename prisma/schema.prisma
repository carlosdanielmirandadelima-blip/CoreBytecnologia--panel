generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  role          String        @default("admin")
  avatarUrl     String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  teamMembers   TeamMember[]
}

model Team {
  id            String        @id @default(cuid())
  name          String
  description   String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  members       TeamMember[]
}

model TeamMember {
  id            String    @id @default(cuid())
  role          String    @default("member")
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId        String
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([userId, teamId])
}

model Project {
  id            String    @id @default(cuid())
  name          String
  description   String    @default("")
  type          String    @default("custom")
  status        String    @default("stopped")
  gitUrl        String    @default("")
  branch        String    @default("main")
  templateId    String    @default("")
  composeFile   String    @default("")
  domain        String    @default("")
  teamId        String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  services      Service[]
  envVars       EnvVar[]
}

model Service {
  id            String    @id @default(cuid())
  name          String
  image         String
  containerId   String    @default("")
  status        String    @default("stopped")
  ports         String    @default("")
  volumes       String    @default("")
  command       String    @default("")
  replicas      Int       @default(1)
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EnvVar {
  id            String    @id @default(cuid())
  key           String
  value         String
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GlobalEnvVar {
  id            String    @id @default(cuid())
  key           String    @unique
  value         String
  description   String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Setting {
  id            String    @id @default(cuid())
  key           String    @unique
  value         String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Backup {
  id            String    @id @default(cuid())
  name          String
  type          String    @default("volume")
  source        String
  fileName      String
  filePath      String
  fileSize      Int       @default(0)
  status        String    @default("pending")
  scheduleId    String?
  schedule      BackupSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
}

model BackupSchedule {
  id            String    @id @default(cuid())
  name          String
  type          String    @default("volume")
  source        String
  cron          String    @default("0 2 * * *")
  retention     Int       @default(7)
  enabled       Boolean   @default(true)
  lastRun       DateTime?
  nextRun       DateTime?
  backups       Backup[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Node {
  id            String    @id @default(cuid())
  name          String
  host          String
  port          Int       @default(2375)
  protocol      String    @default("http")
  tlsCa         String    @default("")
  tlsCert       String    @default("")
  tlsKey        String    @default("")
  status        String    @default("offline")
  isLocal       Boolean   @default(false)
  cpuPercent    Float     @default(0)
  memoryPercent Float     @default(0)
  diskPercent   Float     @default(0)
  containers    Int       @default(0)
  lastCheck     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DnsRecord {
  id            String    @id @default(cuid())
  zoneId        String
  zoneName      String
  recordId      String    @default("")
  type          String    @default("A")
  name          String
  content       String
  proxied       Boolean   @default(true)
  ttl           Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StatusPage {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String    @default("")
  isPublic      Boolean   @default(true)
  monitors      StatusMonitor[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StatusMonitor {
  id            String    @id @default(cuid())
  name          String
  type          String    @default("http")
  target        String
  interval      Int       @default(60)
  timeout       Int       @default(10)
  status        String    @default("unknown")
  lastCheck     DateTime?
  lastResponse  Int       @default(0)
  uptime24h     Float     @default(100)
  pageId        String
  page          StatusPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  checks        StatusCheck[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StatusCheck {
  id            String    @id @default(cuid())
  status        String
  responseTime  Int       @default(0)
  message       String    @default("")
  monitorId     String
  monitor       StatusMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}
